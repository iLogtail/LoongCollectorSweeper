# 复制本文件为 `.env` 后填写。`.env` 已加入 .gitignore，勿提交秘钥。
# 程序从「本仓库根目录」加载 `.env`（与 package.json 同级），与当前 shell 工作目录无关。

# --- 百炼 / DashScope（执行 review 时必需）---
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen3.6-max-preview
# 可选：兼容模式 API 根，默认 https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_HTTP_BASE_URL=

# --- 本地上游克隆（不设则默认 ../loongcollector；CLI 参数优先生效）---
# LOONGSWEEPER_TARGET_REPO_DIR=../loongcollector
# 与上一行二选一，含义相同（别名）
# LOONGCOLLECTOR_LOCAL_DIR=../loongcollector

# --- 文档与 GitHub（可选）---
# LOONGSWEEPER_DOCS_URL=
# 若不用 gh 默认登录，可显式提供（与 CI 命名一致；注意权限最小化）
# LOONGCOLLECTOR_GH_READ_TOKEN=
# LOONGCOLLECTOR_GH_WRITE_TOKEN=
